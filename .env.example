# App — set both to the same value (APP_NAME is server-side; NEXT_PUBLIC_APP_NAME is for client components)
APP_NAME=Sporty Girl Shop
NEXT_PUBLIC_APP_NAME=Sporty Girl Shop
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (test mode at https://dashboard.stripe.com/test)
STRIPE_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_your_connect_webhook_secret

# Fee configuration
COMMODITY_FEE_PERCENT=12
NICHE_FEE_PERCENT=20
PROCESSING_FEE_PERCENT=2.9
PROCESSING_FEE_FLAT=0.30

# Admin access (comma-separated emails)
ADMIN_EMAILS=founder@example.com

# AI (vision-capable — use one or both)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
AI_PROVIDER=openai
ASSISTANT_MODEL=gpt-4o

# Email (Resend — https://resend.com)
RESEND_API_KEY=re_your_key
EMAIL_FROM=notifications@yourdomain.com

# Legal / ToS version tracking
TOS_VERSION=1.0.0
NEXT_PUBLIC_TOS_VERSION=1.0.0
